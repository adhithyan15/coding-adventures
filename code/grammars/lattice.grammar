# Parser grammar for Lattice — a CSS superset language
#
# Lattice extends CSS3 with variables, mixins, control flow, functions, and
# modules. This file is a standalone copy of all CSS grammar rules plus ~20
# new rules for Lattice-specific constructs.
#
# The existing css.grammar is NOT modified. This file is self-contained.
#
# Design principle: every Lattice construct starts with an unambiguous leading
# token. Variables start with VARIABLE ($). All other Lattice constructs use
# AT_KEYWORD tokens (@mixin, @include, @if, @for, @each, @function, @return,
# @use) which are matched via literal text matching — the same mechanism
# proven by BANG "important" in the CSS grammar.
#
# Format: rule_name = definition ;
#
# UPPERCASE names reference tokens from lattice.tokens
# lowercase names reference other grammar rules
#
# Notation:
#   |       alternation (try each choice, first match wins)
#   { x }   zero or more repetitions
#   [ x ]   optional (zero or one)
#   ( x )   grouping
#   "lit"   literal match (matches a token whose text value is that string)

# ============================================================================
# Top-Level Structure
# ============================================================================
#
# A Lattice stylesheet is a sequence of rules. Each rule is either a Lattice
# construct (variable, mixin, function, @use), a CSS at-rule, or a CSS
# qualified rule. Lattice rules are tried FIRST so that @mixin, @if, etc.
# are matched before falling through to the generic CSS at_rule pattern.

stylesheet = { rule } ;

rule = lattice_rule | at_rule | qualified_rule ;

# Lattice-specific top-level constructs. These produce no direct CSS output —
# they define variables, mixins, functions, or import modules.
lattice_rule = variable_declaration
             | mixin_definition
             | function_definition
             | use_directive ;

# ============================================================================
# Lattice: Variables
# ============================================================================
#
# Variable declarations bind a name to a value:
#   $primary-color: #4a90d9;
#   $font-stack: Helvetica, sans-serif;
#   $base-size: 16px;
#
# Variables are referenced by their VARIABLE token ($name) in value positions.

variable_declaration = VARIABLE COLON value_list SEMICOLON ;

# ============================================================================
# Lattice: Mixins
# ============================================================================
#
# Mixins are reusable blocks of declarations (like functions that emit CSS):
#
#   @mixin button($bg, $fg: white) {
#     background: $bg;
#     color: $fg;
#     padding: 8px 16px;
#   }
#
#   .primary-btn {
#     @include button(#4a90d9);
#   }
#
# Mixins can have parameters with optional defaults. The @include directive
# expands the mixin body at the call site.

# Note: name( is tokenized as a single FUNCTION token (e.g., "button("),
# just like CSS functions (rgb(, calc(). So @mixin button(...) produces
# AT_KEYWORD FUNCTION ... RPAREN, not AT_KEYWORD IDENT LPAREN ... RPAREN.
mixin_definition = "@mixin" FUNCTION [ mixin_params ] RPAREN block ;

mixin_params = mixin_param { COMMA mixin_param } ;

# A parameter is a VARIABLE with an optional default value.
# The default is a full value_list (can be multi-token: "Helvetica, sans-serif").
mixin_param = VARIABLE [ COLON value_list ] ;

# @include expands a mixin. Two forms:
#   @include button(red);     → AT_KEYWORD FUNCTION IDENT RPAREN SEMICOLON
#   @include clearfix;        → AT_KEYWORD IDENT SEMICOLON
# The FUNCTION form handles calls with parens, the IDENT form handles
# calls without parens. Both can optionally have a content block.
include_directive = "@include" FUNCTION include_args RPAREN ( SEMICOLON | block )
                  | "@include" IDENT ( SEMICOLON | block ) ;

include_args = value_list { COMMA value_list } ;

# ============================================================================
# Lattice: Control Flow
# ============================================================================
#
# @if / @else if / @else — conditional inclusion:
#   @if $theme == dark {
#     body { background: #1a1a1a; }
#   } @else {
#     body { background: white; }
#   }
#
# @for — numeric iteration:
#   @for $i from 1 through 12 {
#     .col-#{$i} { width: calc(100% / 12 * $i); }
#   }
#
# @each — list iteration:
#   @each $color in red, green, blue {
#     .text { color: $color; }
#   }

lattice_control = if_directive | for_directive | each_directive ;

# @if with optional @else if chains and @else.
# "@else" "if" uses two literal matches: AT_KEYWORD(@else) then IDENT(if).
if_directive = "@if" lattice_expression block
               { "@else" "if" lattice_expression block }
               [ "@else" block ] ;

# @for iterates a variable over a numeric range.
# "through" is inclusive (1 through 3 → 1,2,3).
# "to" is exclusive (1 to 3 → 1,2).
for_directive = "@for" VARIABLE "from" lattice_expression
                ( "through" | "to" ) lattice_expression block ;

# @each iterates over a comma-separated list of values.
# Multiple variables support destructuring: @each $key, $value in $map
each_directive = "@each" VARIABLE { COMMA VARIABLE } "in"
                 each_list block ;

each_list = value { COMMA value } ;

# ============================================================================
# Lattice: Expressions
# ============================================================================
#
# Expressions are used in @if conditions, @for bounds, and @return values.
# They support arithmetic, comparison, and boolean operators.
#
# Operator precedence (tightest to loosest):
#   1. Unary minus: -$x
#   2. Multiplication: $a * $b
#   3. Addition/subtraction: $a + $b, $a - $b
#   4. Comparison: $a == $b, $a > $b, $a >= $b, $a != $b, $a <= $b
#   5. Logical AND: $a and $b
#   6. Logical OR: $a or $b
#
# No division operator — use calc() in value positions or math-div() function.

lattice_expression = lattice_or_expr ;

lattice_or_expr = lattice_and_expr { "or" lattice_and_expr } ;

lattice_and_expr = lattice_comparison { "and" lattice_comparison } ;

lattice_comparison = lattice_additive [ comparison_op lattice_additive ] ;

comparison_op = EQUALS_EQUALS | NOT_EQUALS
              | GREATER | GREATER_EQUALS | LESS_EQUALS ;

lattice_additive = lattice_multiplicative
                   { ( PLUS | MINUS ) lattice_multiplicative } ;

lattice_multiplicative = lattice_unary { STAR lattice_unary } ;

lattice_unary = MINUS lattice_unary | lattice_primary ;

lattice_primary = VARIABLE | NUMBER | DIMENSION | PERCENTAGE
                | STRING | IDENT | HASH
                | "true" | "false" | "null"
                | function_call
                | LPAREN lattice_expression RPAREN ;

# ============================================================================
# Lattice: Functions
# ============================================================================
#
# Functions compute and return values:
#
#   @function spacing($multiplier) {
#     @return $multiplier * 8px;
#   }
#
#   .card { padding: spacing(2); }  →  .card { padding: 16px; }
#
# Functions share the mixin_params rule for parameter syntax. The function
# body is restricted to variable declarations, @return, and control flow
# (no CSS declarations or nested rules).

# Like mixins, name( is a FUNCTION token.
function_definition = "@function" FUNCTION [ mixin_params ] RPAREN
                      function_body ;

function_body = LBRACE { function_body_item } RBRACE ;

function_body_item = variable_declaration | return_directive | lattice_control ;

return_directive = "@return" lattice_expression SEMICOLON ;

# ============================================================================
# Lattice: Modules
# ============================================================================
#
# @use imports another Lattice file's exports (variables, mixins, functions):
#
#   @use "colors";                  — import as namespace "colors"
#   @use "utils/mixins" as m;      — import as namespace "m"
#
# The string is resolved relative to the source file with .lattice extension.

use_directive = "@use" STRING [ "as" IDENT ] SEMICOLON ;

# ============================================================================
# CSS: At-Rules (unchanged from css.grammar)
# ============================================================================
#
# CSS at-rules share a common structure:
#   AT_KEYWORD prelude (SEMICOLON | block)
#
# This rule handles all CSS at-rules that are NOT Lattice-specific.
# Lattice at-keywords (@mixin, @if, etc.) are matched BEFORE this rule
# because lattice_rule appears first in the rule alternation.

at_rule = AT_KEYWORD at_prelude ( SEMICOLON | block ) ;

at_prelude = { at_prelude_token } ;

at_prelude_token = IDENT | STRING | NUMBER | DIMENSION | PERCENTAGE
                 | HASH | CUSTOM_PROPERTY | UNICODE_RANGE
                 | VARIABLE
                 | function_in_prelude | paren_block
                 | COLON | COMMA | SLASH | DOT | STAR | PLUS | MINUS
                 | GREATER | TILDE | PIPE | EQUALS | AMPERSAND
                 | CDO | CDC ;

function_in_prelude = FUNCTION at_prelude_tokens RPAREN ;
paren_block = LPAREN at_prelude_tokens RPAREN ;
at_prelude_tokens = { at_prelude_token } ;

# ============================================================================
# CSS: Qualified Rules (unchanged from css.grammar)
# ============================================================================

qualified_rule = selector_list block ;

# ============================================================================
# CSS: Selectors (unchanged from css.grammar)
# ============================================================================

selector_list = complex_selector { COMMA complex_selector } ;

complex_selector = compound_selector { [ combinator ] compound_selector } ;

combinator = GREATER | PLUS | TILDE ;

compound_selector = simple_selector { subclass_selector }
                  | subclass_selector { subclass_selector } ;

simple_selector = IDENT | STAR | AMPERSAND ;

subclass_selector = class_selector | id_selector
                  | attribute_selector | pseudo_class
                  | pseudo_element ;

class_selector = DOT IDENT ;

id_selector = HASH ;

attribute_selector = LBRACKET IDENT [ attr_matcher attr_value [ IDENT ] ] RBRACKET ;

attr_matcher = EQUALS | TILDE_EQUALS | PIPE_EQUALS
             | CARET_EQUALS | DOLLAR_EQUALS | STAR_EQUALS ;

attr_value = IDENT | STRING ;

pseudo_class = COLON FUNCTION pseudo_class_args RPAREN
             | COLON IDENT ;

pseudo_class_args = { pseudo_class_arg } ;

pseudo_class_arg = IDENT | NUMBER | DIMENSION | STRING | HASH
                 | PLUS | COMMA | DOT | STAR | COLON | AMPERSAND
                 | FUNCTION pseudo_class_args RPAREN
                 | LBRACKET pseudo_class_args RBRACKET ;

pseudo_element = COLON_COLON IDENT ;

# ============================================================================
# CSS: Declaration Block (extended for Lattice)
# ============================================================================
#
# A block contains declarations, nested rules, and Lattice constructs.
# Lattice block items (variables, @include, control flow) are tried FIRST
# so they are matched before attempting CSS declaration parsing.

block = LBRACE block_contents RBRACE ;

block_contents = { block_item } ;

block_item = lattice_block_item | at_rule | declaration_or_nested ;

# Lattice constructs valid inside blocks. These are different from top-level
# lattice_rule — blocks can contain @include and control flow, but NOT
# mixin/function definitions or @use directives.
lattice_block_item = variable_declaration
                   | include_directive
                   | lattice_control ;

declaration_or_nested = declaration | qualified_rule ;

# ============================================================================
# CSS: Declarations (unchanged from css.grammar)
# ============================================================================

declaration = property COLON value_list [ priority ] SEMICOLON ;

property = IDENT | CUSTOM_PROPERTY ;

priority = BANG "important" ;

# ============================================================================
# CSS: Values (extended with VARIABLE for Lattice)
# ============================================================================
#
# The value rule adds VARIABLE to the list of valid value tokens. This
# allows $var references in declaration values:
#   color: $brand-color;
#   padding: $base-spacing;

value_list = value { value } ;

value = DIMENSION | PERCENTAGE | NUMBER | STRING | IDENT | HASH
      | CUSTOM_PROPERTY | UNICODE_RANGE | function_call
      | VARIABLE
      | SLASH | COMMA | PLUS | MINUS ;

function_call = FUNCTION function_args RPAREN
              | URL_TOKEN ;

function_args = { function_arg } ;

function_arg = DIMENSION | PERCENTAGE | NUMBER | STRING | IDENT | HASH
             | CUSTOM_PROPERTY | COMMA | SLASH | PLUS | MINUS | STAR
             | VARIABLE
             | FUNCTION function_args RPAREN ;
