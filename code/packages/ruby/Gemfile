# Workspace Gemfile — lists all gems as path dependencies for local development.
#
# When developing locally, Bundler resolves inter-gem dependencies from the
# local paths below. When published to RubyGems, each gem's .gemspec declares
# the real version-pinned dependencies.
#
# Usage:
#   cd code/packages/ruby
#   bundle install
#   bundle exec rake test    # runs tests for all gems

