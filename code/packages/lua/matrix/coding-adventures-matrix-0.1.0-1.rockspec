package = "coding-adventures-matrix"
version = "0.1.0-1"
source = {
    url = "git://github.com/adhithyan15/coding-adventures.git",
}
description = {
    summary = "2D matrix type with arithmetic and linear-algebra operations",
    license = "MIT",
}
dependencies = {
    "lua >= 5.4",
}
build = {
    type = "builtin",
    modules = {
        ["coding_adventures.matrix"] = "src/coding_adventures/matrix/init.lua",
    },
}
