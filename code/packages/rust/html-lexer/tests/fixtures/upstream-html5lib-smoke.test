      "description": "data state named character references use the longest matching prefix",
      "input": "Text &notit; &copycat &sumtotal",
      "output": [
        ["Character", "Text "],
        ["Character", "\u00AC"],
        ["Character", "it; "],
        ["Character", "\u00A9"],
        ["Character", "cat "],
        ["Character", "\u2211"],
        ["Character", "total"]
      ],
      "errors": [
        {"code": "missing-semicolon-after-character-reference", "line": 1, "col": 10},
