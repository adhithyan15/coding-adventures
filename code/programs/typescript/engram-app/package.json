{
  "name": "engram-app",
  "version": "0.1.0",
  "private": true,
  "description": "Engram — Anki-style spaced repetition desktop app with SM-2 scheduling",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "tsc -p electron/tsconfig.json && cross-env VITE_DEV_SERVER_URL=http://localhost:5173/ electron dist-electron/main.js",
    "electron:build": "npm run build && tsc -p electron/tsconfig.json && electron-builder",
    "electron:build:win": "npm run build && tsc -p electron/tsconfig.json && electron-builder --win",
    "electron:build:mac": "npm run build && tsc -p electron/tsconfig.json && electron-builder --mac",
    "electron:build:linux": "npm run build && tsc -p electron/tsconfig.json && electron-builder --linux"
  },
  "dependencies": {
    "@coding-adventures/indexeddb": "file:../../../packages/typescript/indexeddb",
    "@coding-adventures/store": "file:../../../packages/typescript/store",
    "@coding-adventures/ui-components": "file:../../../packages/typescript/ui-components",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "jsdom": "^25.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "cross-env": "^7.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adhithyan15/coding-adventures.git",
    "directory": "code/programs/typescript/engram-app"
  },
  "author": "Adhithya Rajasekaran",
  "license": "MIT"
}
