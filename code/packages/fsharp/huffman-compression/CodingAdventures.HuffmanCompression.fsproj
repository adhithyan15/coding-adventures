<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>CodingAdventures.HuffmanCompression.FSharp</PackageId>
    <Version>0.1.0</Version>
    <Authors>Adhithya Rajasekaran</Authors>
    <Description>Pure F# CMP04 Huffman lossless compression with canonical wire-format helpers</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../huffman-tree/CodingAdventures.HuffmanTree.fsproj" />
    <Compile Include="HuffmanCompression.fs" />
  </ItemGroup>
</Project>
