{
  "$schema": "https://raw.githubusercontent.com/adhithyan15/coding-adventures/main/code/specs/schemas/required_capabilities.schema.json",
  "version": 1,
  "package": "go/typescript-lexer",
  "capabilities": [
    {
      "category": "fs",
      "action": "read",
      "target": "../../../grammars/typescript.tokens",
      "justification": "Generic TypeScript token grammar (no version specified)."
    },
    {
      "category": "fs",
      "action": "read",
      "target": "../../../grammars/typescript/ts1.0.tokens",
      "justification": "TypeScript 1.0 token grammar (April 2014)."
    },
    {
      "category": "fs",
      "action": "read",
      "target": "../../../grammars/typescript/ts2.0.tokens",
      "justification": "TypeScript 2.0 token grammar (September 2016)."
    },
    {
      "category": "fs",
      "action": "read",
      "target": "../../../grammars/typescript/ts3.0.tokens",
      "justification": "TypeScript 3.0 token grammar (July 2018)."
    },
    {
      "category": "fs",
      "action": "read",
      "target": "../../../grammars/typescript/ts4.0.tokens",
      "justification": "TypeScript 4.0 token grammar (August 2020)."
    },
    {
      "category": "fs",
      "action": "read",
      "target": "../../../grammars/typescript/ts5.0.tokens",
      "justification": "TypeScript 5.0 token grammar (March 2023)."
    },
    {
      "category": "fs",
      "action": "read",
      "target": "../../../grammars/typescript/ts5.8.tokens",
      "justification": "TypeScript 5.8 token grammar (February 2025)."
    }
  ],
  "justification": "Reads grammar definition files for the selected TypeScript version. No write, network, or process access needed."
}
