{
  "cli_builder_spec_version": "1.0",
  "name": "echo",
  "display_name": "echo",
  "description": "Display a line of text. Write arguments to standard output, separated by single spaces, followed by a newline.",
  "version": "1.0.0",
  "parsing_mode": "posix",
  "builtin_flags": { "help": true, "version": true },
  "flags": [
    {
      "id": "no_newline",
      "short": "n",
      "description": "Do not output the trailing newline",
      "type": "boolean"
    },
    {
      "id": "enable_escapes",
      "short": "e",
      "description": "Enable interpretation of backslash escapes",
      "type": "boolean"
    },
    {
      "id": "disable_escapes",
      "short": "E",
      "description": "Disable interpretation of backslash escapes (default)",
      "type": "boolean"
    }
  ],
  "arguments": [
    {
      "id": "strings",
      "name": "STRING",
      "description": "Strings to display",
      "required": false,
      "variadic": true,
      "type": "string"
    }
  ],
  "commands": [],
  "mutually_exclusive_groups": [
    {
      "id": "escape-mode",
      "flag_ids": ["enable_escapes", "disable_escapes"],
      "required": false
    }
  ]
}
