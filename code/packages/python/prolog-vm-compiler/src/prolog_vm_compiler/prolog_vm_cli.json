{
  "cli_builder_spec_version": "1.0",
  "name": "prolog-vm",
  "description": "Run SWI/ISO-compatible Prolog source through the Logic VM or Logic bytecode VM.",
  "version": "0.1.0",
  "parsing_mode": "gnu",
  "builtin_flags": {
    "help": true,
    "version": true
  },
  "flags": [
    {
      "id": "source",
      "long": "source",
      "description": "Inline Prolog source text to load instead of file paths.",
      "type": "string",
      "value_name": "SOURCE"
    },
    {
      "id": "query",
      "long": "query",
      "description": "Ad-hoc top-level query to run; may be repeated for a stateful query script.",
      "type": "string",
      "value_name": "QUERY",
      "repeatable": true
    },
    {
      "id": "source-query-index",
      "long": "source-query-index",
      "description": "Zero-based source-level ?- query index to run when --query is absent.",
      "type": "integer",
      "default": 0,
      "value_name": "INDEX"
    },
    {
      "id": "query-module",
      "long": "query-module",
      "description": "Module context for ad-hoc project/file-graph queries.",
      "type": "string",
      "value_name": "MODULE"
    },
    {
      "id": "limit",
      "long": "limit",
      "description": "Maximum number of answers to print.",
      "type": "integer",
      "value_name": "N"
    },
    {
      "id": "dialect",
      "long": "dialect",
      "description": "Prolog dialect profile to use.",
      "type": "enum",
      "enum_values": ["swi", "iso"],
      "default": "swi",
      "value_name": "DIALECT"
    },
    {
      "id": "backend",
      "long": "backend",
      "description": "VM backend to execute with.",
      "type": "enum",
      "enum_values": ["structured", "bytecode"],
      "default": "structured",
      "value_name": "BACKEND"
    },
    {
      "id": "values",
      "long": "values",
      "description": "Print raw answer values instead of named variable bindings.",
      "type": "boolean"
    },
    {
      "id": "commit",
      "long": "commit",
      "description": "Commit the first answer state from each ad-hoc query so dynamic updates persist across repeated queries or REPL input.",
      "type": "boolean"
    },
    {
      "id": "interactive",
      "short": "i",
      "long": "interactive",
      "description": "Start a small top-level query loop after loading the source, file, or project.",
      "type": "boolean"
    },
    {
      "id": "no-initialize",
      "long": "no-initialize",
      "description": "Do not run initialization directives before the selected query.",
      "type": "boolean"
    }
  ],
  "arguments": [
    {
      "id": "files",
      "name": "FILE",
      "description": "Prolog file or linked file graph to load.",
      "type": "path",
      "required": false,
      "variadic": true,
      "variadic_min": 0,
      "variadic_max": null
    }
  ]
}
