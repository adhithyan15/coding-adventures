{
  "name": "bookmarks-extension",
  "version": "0.1.0",
  "private": true,
  "description": "A browser extension for saving annotated bookmarks with a pluggable storage backend",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:release": "vite build && npx tsx scripts/build-all-browsers.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@coding-adventures/browser-extension-toolkit": "file:../../../packages/typescript/browser-extension-toolkit"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^25.0.0",
    "tsx": "^4.0.0",
    "fake-indexeddb": "^6.0.0"
  }
}
