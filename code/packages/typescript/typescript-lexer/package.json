{
  "name": "@coding-adventures/typescript-lexer",
  "version": "0.1.0",
  "description": "Tokenizes TypeScript source code using the grammar-driven lexer — a thin wrapper that loads typescript.tokens",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "typescript",
    "lexer",
    "tokenizer",
    "grammar-driven",
    "computer-science",
    "education"
  ],
  "author": "Adhithya Rajasekaran",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
