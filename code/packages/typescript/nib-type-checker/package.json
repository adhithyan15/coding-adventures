    "@coding-adventures/type-checker-protocol": "file:../type-checker-protocol"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.0.0",
