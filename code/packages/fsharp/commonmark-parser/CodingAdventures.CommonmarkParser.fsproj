<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <AssemblyName>CodingAdventures.CommonmarkParser.FSharp</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>CodingAdventures.CommonmarkParser.FSharp</PackageId>
    <Version>0.1.0</Version>
    <Authors>Adhithya Rajasekaran</Authors>
    <Description>Pure F# CommonMark parser that produces the document AST</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../fsharp/document-ast/CodingAdventures.DocumentAst.fsproj" />
    <Compile Include="CommonmarkParser.fs" />
  </ItemGroup>
</Project>
