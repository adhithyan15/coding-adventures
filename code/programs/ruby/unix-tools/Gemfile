# frozen_string_literal: true

source "https://rubygems.org"

# ---------------------------------------------------------------------------
# Runtime dependency: CLI Builder
# ---------------------------------------------------------------------------
# CLI Builder is the declarative argument-parsing library that reads our
# pwd.json spec and handles all flag parsing, help generation, version
# output, and error messaging. We reference it by local path so that
# development uses the version checked into this repository.
gem "coding_adventures_cli_builder", path: "../../../packages/ruby/cli_builder"

# ---------------------------------------------------------------------------
# Transitive dependencies of CLI Builder
# ---------------------------------------------------------------------------
# CLI Builder depends on state_machine, which depends on directed_graph.
# directed_graph depends on graph, so Bundler needs local path references for
# all three gems so it can resolve the full dependency graph without hitting
# RubyGems.
gem "coding_adventures_graph", path: "../../../packages/ruby/graph"
gem "coding_adventures_state_machine", path: "../../../packages/ruby/state_machine"
gem "coding_adventures_directed_graph", path: "../../../packages/ruby/directed_graph"

# ---------------------------------------------------------------------------
# Development and test dependencies
# ---------------------------------------------------------------------------
group :test do
  gem "minitest", "~> 5.0"
  gem "rake", "~> 13.0"
  gem "simplecov", "~> 0.22", require: false
end
