{
  "name": "@coding-adventures/ca-capability-analyzer",
  "version": "0.1.0",
  "description": "Static analyzer that walks TypeScript/JavaScript ASTs to detect OS capability usage and compares against declared capabilities.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "ca-capability-analyzer": "src/cli.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "capability",
    "analyzer",
    "static-analysis",
    "ast",
    "typescript",
    "security"
  ],
  "author": "Adhithya Rajasekaran",
  "license": "MIT",
  "dependencies": {
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
