<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>CodingAdventures.PaintVm</PackageId>
    <Version>0.1.0</Version>
    <Authors>Adhithya Rajasekaran</Authors>
    <Description>Dispatch-table virtual machine for PaintInstructions</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../paint-instructions/CodingAdventures.PaintInstructions.fsproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="PaintVm.fs" />
  </ItemGroup>
</Project>
