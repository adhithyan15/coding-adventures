{
  "cli_builder_spec_version": "1.0",
  "name": "basename",
  "display_name": "basename",
  "description": "Strip directory and suffix from filenames",
  "version": "1.0.0",
  "parsing_mode": "gnu",
  "builtin_flags": {
    "help": true,
    "version": true
  },
  "flags": [
    {
      "id": "multiple",
      "short": "a",
      "long": "multiple",
      "description": "Support multiple arguments and treat each as a NAME",
      "type": "boolean"
    },
    {
      "id": "suffix",
      "short": "s",
      "long": "suffix",
      "description": "Remove a trailing SUFFIX; implies -a",
      "type": "string"
    },
    {
      "id": "zero",
      "short": "z",
      "long": "zero",
      "description": "End each output line with NUL, not newline",
      "type": "boolean"
    }
  ],
  "arguments": [
    {
      "id": "name",
      "description": "Filename(s) to strip",
      "type": "string",
      "required": true,
      "variadic": true,
      "variadic_min": 1,
      "display_name": "NAME"
    }
  ],
  "commands": [],
  "mutually_exclusive_groups": []
}
