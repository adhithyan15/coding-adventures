{
  "name": "engram-electron",
  "version": "0.2.0",
  "private": true,
  "description": "Engram — Electron desktop wrapper for the engram-app web app",
  "type": "commonjs",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173/ electron dist-electron/main.js",
    "build": "tsc -p electron/tsconfig.json",
    "electron:build": "electron-builder",
    "electron:build:win": "electron-builder --win",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "engram-app": "file:../engram-app",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "cross-env": "^7.0.0",
    "typescript": "~5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adhithyan15/coding-adventures.git",
    "directory": "code/programs/typescript/engram-electron"
  },
  "author": "Adhithya Rajasekaran",
  "license": "MIT"
}
