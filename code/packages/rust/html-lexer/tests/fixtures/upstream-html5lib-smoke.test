        ["Character", "\u2146"],
        ["Character", "\u2145"],
        ["Character", "\u2145"],
        ["Character", "\u2146"],
        ["Character", "\u2147"],
        ["Character", "\u2147"],
        ["Character", "\u2148"],
        ["Character", "\u2148"],
        ["EndTag", "title"]
      ]
    },
