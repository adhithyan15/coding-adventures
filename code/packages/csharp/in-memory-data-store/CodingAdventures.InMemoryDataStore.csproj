<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>CodingAdventures.InMemoryDataStore.CSharp</PackageId>
    <Version>0.1.0</Version>
    <Authors>Adhithya Rajasekaran</Authors>
    <Description>Pure C# Mini-Redis RESP facade</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="tests\**\*.cs" />
    <EmbeddedResource Remove="tests\**" />
    <None Remove="tests\**" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../in-memory-data-store-engine/CodingAdventures.InMemoryDataStoreEngine.csproj" />
    <ProjectReference Include="../in-memory-data-store-protocol/CodingAdventures.InMemoryDataStoreProtocol.csproj" />
    <ProjectReference Include="../resp-protocol/CodingAdventures.RespProtocol.csproj" />
  </ItemGroup>
</Project>
