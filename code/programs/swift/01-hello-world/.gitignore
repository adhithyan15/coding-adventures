# Xcode project — generated by xcodegen from project.yml.
# The .xcodeproj is committed so Xcode can open the project directly.
# DerivedData and user-specific files are excluded.
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
DerivedData/
*.xccheckout
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
