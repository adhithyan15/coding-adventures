<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>CodingAdventures.ImageGeometricTransforms</PackageId>
    <Version>0.1.0</Version>
    <Authors>Adhithya Rajasekaran</Authors>
    <Description>IMG04: Geometric transforms on PixelContainer</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../pixel-container/CodingAdventures.PixelContainer.fsproj" />
    <Compile Include="ImageGeometricTransforms.fs" />
  </ItemGroup>
</Project>
