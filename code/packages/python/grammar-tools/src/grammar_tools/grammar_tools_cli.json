{
  "cli_builder_spec_version": "1.0",
  "name": "grammar-tools",
  "display_name": "grammar-tools",
  "description": "Compile .tokens and .grammar files into Python modules.",
  "version": "0.1.0",
  "parsing_mode": "gnu",
  "builtin_flags": {
    "help": true,
    "version": true
  },
  "commands": [
    {
      "id": "compile-tokens",
      "name": "compile-tokens",
      "description": "Compile a .tokens file into a Python TOKEN_GRAMMAR module.",
      "flags": [
        {
          "id": "output",
          "short": "o",
          "long": "output",
          "description": "Output Python module path. Defaults to stdout.",
          "type": "path",
          "value_name": "PY"
        }
      ],
      "arguments": [
        {
          "id": "source",
          "display_name": "SOURCE",
          "description": ".tokens file to compile.",
          "type": "file",
          "required": true
        }
      ]
    },
    {
      "id": "compile-grammar",
      "name": "compile-grammar",
      "description": "Compile a .grammar file into a Python PARSER_GRAMMAR module.",
      "flags": [
        {
          "id": "output",
          "short": "o",
          "long": "output",
          "description": "Output Python module path. Defaults to stdout.",
          "type": "path",
          "value_name": "PY"
        }
      ],
      "arguments": [
        {
          "id": "source",
          "display_name": "SOURCE",
          "description": ".grammar file to compile.",
          "type": "file",
          "required": true
        }
      ]
    }
  ]
}
