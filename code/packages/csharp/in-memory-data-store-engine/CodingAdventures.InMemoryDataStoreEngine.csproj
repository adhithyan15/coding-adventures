<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>CodingAdventures.InMemoryDataStoreEngine.CSharp</PackageId>
    <Version>0.1.0</Version>
    <Authors>Adhithya Rajasekaran</Authors>
    <Description>Pure C# Mini-Redis in-memory command engine</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="tests\**\*.cs" />
    <EmbeddedResource Remove="tests\**" />
    <None Remove="tests\**" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../hash-map/CodingAdventures.HashMap.csproj" />
    <ProjectReference Include="../hash-set/CodingAdventures.HashSet.csproj" />
    <ProjectReference Include="../heap/CodingAdventures.Heap.csproj" />
    <ProjectReference Include="../hyperloglog/CodingAdventures.HyperLogLog.csproj" />
    <ProjectReference Include="../skip-list/CodingAdventures.SkipList.csproj" />
    <ProjectReference Include="../resp-protocol/CodingAdventures.RespProtocol.csproj" />
    <ProjectReference Include="../in-memory-data-store-protocol/CodingAdventures.InMemoryDataStoreProtocol.csproj" />
  </ItemGroup>
</Project>
