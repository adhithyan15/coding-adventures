# frozen_string_literal: true

# ================================================================
# Rakefile -- Build task definitions for correlation_vector
# ================================================================
#
# Rake is Ruby's standard build tool (like Make, but in Ruby).
# This Rakefile defines one task:
#
#   rake test  -- Run all files matching test/**/*_test.rb or
#                 test/**/test_*.rb using Minitest
#
# The `:default` task means `rake` with no arguments runs the tests.
#
# Why Rake and not just `ruby test/...`?
# =======================================
# Rake handles multiple test files, load path setup, and integrates
# with SimpleCov for coverage. It's also what CI expects for Ruby
# gems -- a single entry point that runs everything.
# ================================================================

require "rake/testtask"

Rake::TestTask.new(:test) do |t|
  # Add test/ and lib/ to the Ruby load path so `require` works.
  t.libs << "test"
  t.libs << "lib"

  # Match both common test file naming conventions:
  # - test/test_something.rb  (our convention)
  # - test/something_test.rb  (Rails convention)
  t.test_files = FileList["test/**/*_test.rb", "test/**/test_*.rb"]
end

# Running `rake` with no arguments runs the test suite.
task default: :test
