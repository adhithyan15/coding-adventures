<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>CodingAdventures.JsonSerializer.FSharp</PackageId>
    <Version>0.1.0</Version>
    <Authors>Adhithya Rajasekaran</Authors>
    <Description>Compact and pretty JSON serialization for JsonValue trees and native .NET values</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="JsonSerializer.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../json-value/CodingAdventures.JsonValue.fsproj" />
  </ItemGroup>
</Project>
