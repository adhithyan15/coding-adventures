<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>CodingAdventures.PDF417.FSharp</PackageId>
    <Version>0.1.0</Version>
    <Authors>Adhithya Rajasekaran</Authors>
    <Description>ISO/IEC 15438:2015-compliant PDF417 stacked linear barcode encoder for F# — produces a ModuleGrid scannable by any standard decoder</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../barcode-2d/CodingAdventures.Barcode2D.fsproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="PDF417.fs" />
  </ItemGroup>
</Project>
