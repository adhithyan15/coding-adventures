<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>CodingAdventures.Barcode2D.FSharp</PackageId>
    <Version>0.1.0</Version>
    <Authors>Adhithya Rajasekaran</Authors>
    <Description>Universal 2D barcode module-grid abstraction and pixel-layout engine for F#</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../../paint-instructions/CodingAdventures.PaintInstructions.fsproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="Barcode2D.fs" />
  </ItemGroup>
</Project>
