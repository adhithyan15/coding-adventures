{
  "name": "@coding-adventures/ecmascript-es5-lexer",
  "version": "0.1.0",
  "description": "Tokenizes ECMAScript 5 (2009) source code using the grammar-driven lexer — a thin wrapper that loads es5.tokens",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ecmascript",
    "es5",
    "lexer",
    "tokenizer",
    "grammar-driven",
    "computer-science",
    "education"
  ],
  "author": "Adhithya Rajasekaran",
  "license": "MIT",
  "dependencies": {
    "@coding-adventures/lexer": "file:../lexer",
    "@coding-adventures/grammar-tools": "file:../grammar-tools",
    "@coding-adventures/directed-graph": "file:../directed-graph"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
