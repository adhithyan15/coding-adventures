{
  "name": "@coding-adventures/vhdl-lexer",
  "version": "0.1.0",
  "description": "Tokenizes VHDL (IEEE 1076-2008) source code using the grammar-driven lexer, with case normalization for identifiers and keywords",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "vhdl",
    "hdl",
    "lexer",
    "tokenizer",
    "grammar-driven",
    "computer-science",
    "education"
  ],
  "author": "Adhithya Rajasekaran",
  "license": "MIT",
  "dependencies": {
    "@coding-adventures/lexer": "file:../lexer",
    "@coding-adventures/grammar-tools": "file:../grammar-tools",
    "@coding-adventures/directed-graph": "file:../directed-graph",
    "@coding-adventures/state-machine": "file:../state-machine"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
