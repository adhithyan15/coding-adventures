{
  "name": "@coding-adventures/ruby-parser",
  "version": "0.1.0",
  "description": "Parses Ruby source code into ASTs using the grammar-driven parser — a thin wrapper that loads ruby.grammar",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ruby",
    "parser",
    "ast",
    "grammar-driven",
    "computer-science",
    "education"
  ],
  "author": "Adhithya Rajasekaran",
  "license": "MIT",
  "dependencies": {
    "@coding-adventures/lexer": "file:../lexer",
    "@coding-adventures/grammar-tools": "file:../grammar-tools",
    "@coding-adventures/parser": "file:../parser",
    "@coding-adventures/ruby-lexer": "file:../ruby-lexer"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
