# @version 1

# Escape sequences in strings are left as raw text. The Lisp evaluator
# decodes \n, \t, \\, etc. — it is not the lexer's job.
escapes: none

skip:
  WHITESPACE = /[ \t\r\n]+/
  COMMENT    = /;[^\n]*/

NUMBER = /-?[0-9]+/
SYMBOL = /[a-zA-Z_+\-*\/=<>!?&][a-zA-Z0-9_+\-*\/=<>!?&]*/
STRING = /"([^"\\]|\\.)*"/
LPAREN = "("
RPAREN = ")"
QUOTE  = "'"
DOT    = "."
