<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
    <PackageId>CodingAdventures.WasmValidator</PackageId>
    <Version>0.1.0</Version>
    <Authors>Adhithya Rajasekaran</Authors>
    <Description>Pure C# WebAssembly validator</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="tests\**\*.cs" />
    <EmbeddedResource Remove="tests\**" />
    <None Remove="tests\**" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../wasm-leb128/CodingAdventures.WasmLeb128.csproj" />
    <ProjectReference Include="../wasm-opcodes/CodingAdventures.WasmOpcodes.csproj" />
    <ProjectReference Include="../wasm-types/CodingAdventures.WasmTypes.csproj" />
  </ItemGroup>
</Project>
